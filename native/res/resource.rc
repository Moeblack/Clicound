#pragma code_page(65001)
#include <windows.h>
#include "resource.h"

IDI_APPICON ICON "icon.ico"

/* RC 编译器无法解析 commctrl.h，手动定义所需的样式常量 */
#ifndef TBS_AUTOTICKS
#define TBS_AUTOTICKS 0x0001
#endif
#ifndef WS_TABSTOP
#define WS_TABSTOP 0x00010000L
#endif
/* WS_GROUP 在 RC 编译器 include 路径不完整时可能找不到 */
#ifndef WS_GROUP
#define WS_GROUP 0x00020000L
#endif

1 RT_MANIFEST "app.manifest"

IDD_SETTINGS DIALOGEX 0, 0, 340, 270
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Clicound 设置"
FONT 9, "MS Shell Dlg"
BEGIN
    GROUPBOX        "点击音效", -1, 7, 7, 326, 72
    LTEXT           "左键:", -1, 14, 22, 24, 8
    EDITTEXT        IDC_EDIT_LEFT, 40, 20, 230, 12, ES_AUTOHSCROLL | ES_READONLY
    PUSHBUTTON      "浏览", IDC_BTN_LEFT, 275, 19, 50, 14
    LTEXT           "中键:", -1, 14, 38, 28, 8
    EDITTEXT        IDC_EDIT_MIDDLE, 40, 36, 230, 12, ES_AUTOHSCROLL | ES_READONLY
    PUSHBUTTON      "浏览", IDC_BTN_MIDDLE, 275, 35, 50, 14
    LTEXT           "右键:", -1, 14, 54, 24, 8
    EDITTEXT        IDC_EDIT_RIGHT, 40, 52, 230, 12, ES_AUTOHSCROLL | ES_READONLY
    PUSHBUTTON      "浏览", IDC_BTN_RIGHT, 275, 51, 50, 14

    GROUPBOX        "滚轮音效", -1, 7, 83, 326, 52
    LTEXT           "向上:", -1, 14, 98, 24, 8
    EDITTEXT        IDC_EDIT_SCROLLUP, 40, 96, 230, 12, ES_AUTOHSCROLL | ES_READONLY
    PUSHBUTTON      "浏览", IDC_BTN_SCROLLUP, 275, 95, 50, 14
    LTEXT           "向下:", -1, 14, 114, 24, 8
    EDITTEXT        IDC_EDIT_SCROLLDOWN, 40, 112, 230, 12, ES_AUTOHSCROLL | ES_READONLY
    PUSHBUTTON      "浏览", IDC_BTN_SCROLLDOWN, 275, 111, 50, 14

    LTEXT           "启用:", -1, 7, 145, 28, 8
    AUTOCHECKBOX    "左键", IDC_CHK_LEFT, 38, 144, 36, 10
    AUTOCHECKBOX    "中键", IDC_CHK_MIDDLE, 76, 144, 36, 10
    AUTOCHECKBOX    "右键", IDC_CHK_RIGHT, 114, 144, 36, 10
    AUTOCHECKBOX    "滚轮", IDC_CHK_SCROLL, 152, 144, 36, 10

    LTEXT           "音量:", -1, 7, 168, 30, 8
    CONTROL         "", IDC_SLIDER_VOLUME, "msctls_trackbar32", TBS_AUTOTICKS | WS_TABSTOP, 40, 165, 192, 16
    LTEXT           "70%", IDC_LABEL_VOLUME, 238, 168, 28, 8
    PUSHBUTTON      "▶ 试听", IDC_BTN_PREVIEW, 272, 165, 55, 16

    LTEXT           "滚轮灵敏度:", -1, 7, 192, 66, 8
    CONTROL         "", IDC_SLIDER_SENSITIVITY, "msctls_trackbar32", TBS_AUTOTICKS | WS_TABSTOP, 76, 189, 192, 16
    LTEXT           "低=少而稳 高=每格都响", IDC_LABEL_SENSITIVITY, 273, 189, 60, 16

    LTEXT           "触发时机:", -1, 7, 218, 36, 8
    AUTORADIOBUTTON "按下时发声", IDC_RADIO_PRESS, 46, 217, 60, 10, WS_GROUP
    AUTORADIOBUTTON "释放时发声", IDC_RADIO_RELEASE, 110, 217, 60, 10

    DEFPUSHBUTTON   "确定", IDOK, 220, 248, 55, 16
    PUSHBUTTON      "取消", IDCANCEL, 280, 248, 55, 16
END
